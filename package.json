{
  "name": "flyash-logistics-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "esbuild index.ts --bundle --platform=node --format=esm --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" --external:pg-native --external:sqlite3 --external:better-sqlite3 --external:mysql --external:mysql2 --external:oracledb --external:mssql --external:mongodb --external:redis --external:ioredis --external:expo-sqlite --external:react-native-sqlite-storage --external:nativescript-sqlite --external:@sap/hana-client --external:hdb-pool --external:@google-cloud/spanner --external:sql.js --external:typeorm-aurora-data-api-driver --sourcemap --outfile=../dist/server.mjs",
    "start": "node ../dist/server.mjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "tsx": "^4.22.3",
    "typescript": "~5.8.2"
  }
}
