{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "lib": ["ES2022"],
    "types": ["node"],
    "skipLibCheck": true,
    "resolveJsonModule": true,

    "noEmit": false,
    "outDir": "./dist"
  }
}